# 后端环境变量示例（复制为 .env 后填写真实值，.env 不进 Git）

# 数据库（本地 SQLite；上线切 PostgreSQL 只改此处）
DATABASE_URL=sqlite:///./data/app.db

# LLM（OpenAI 兼容 / Azure OpenAI）
# 方式 A：Azure OpenAI（如 ByteDance modelhub）—— 填 AZURE_ENDPOINT 即走 Azure 协议
AZURE_ENDPOINT=
OPENAI_API_VERSION=2024-02-01
# 方式 B：标准 OpenAI 兼容（如 DeepSeek）—— 留空 AZURE_ENDPOINT，填 OPENAI_BASE_URL
# DeepSeek 示例：OPENAI_BASE_URL=https://api.deepseek.com  OPENAI_MODEL=deepseek-v4-pro
OPENAI_BASE_URL=
# 两种方式共用：
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-2025-12-11
# 可选：固定 X-TT-LOGID（留空则每请求自动生成）
TT_LOGID=

# 推理参数（可选，DeepSeek / GPT-5 等推理模型）：普通模型留空即不发送。
# 力度：minimal / low / medium / high
OPENAI_REASONING_EFFORT=
# DeepSeek 思考模式：disabled=关 / enabled=开 / 留空=模型默认。
# 重要：deepseek-v4 等模型默认开思考，会先生成思维链（被本应用丢弃）导致首字延迟很高；
# 本应用只需结构化 JSON，建议 disabled —— 必须显式关闭，仅省略不生效。
OPENAI_THINKING=disabled

# 高德地图 Web 服务 Key（可选）。不填也能本地跑通；POI / 交通会走本地兜底。
AMAP_KEY=

# 鉴权（M5 启用；本地随便填一个长随机串即可）
JWT_SECRET=dev-only-change-me

# CORS 放行的前端来源（逗号分隔）。Vite 5173 被占用时会自动切到 5174。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
